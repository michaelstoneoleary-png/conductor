{
  "name": "conductor-backend",
  "version": "1.0.0",
  "description": "Conductor backend agent engine",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "node dist/worker/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker/index.ts",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "ts-node src/seed.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^5.22.0",
    "fastify": "^4.28.1",
    "node-cron": "^3.0.3",
    "openai": "^6.25.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.9",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
