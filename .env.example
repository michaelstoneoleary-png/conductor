# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/conductor"

# ── LLM API Keys ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."

# ── Security ──────────────────────────────────────────────────────────────────
# Shared secret sent as X-Api-Key header from frontend and worker.
# Generate with: openssl rand -hex 32
CONDUCTOR_API_KEY="change-me-before-production"

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave unset to allow all (dev only).
# CORS_ORIGINS="https://your-frontend.onrender.com,https://your-custom-domain.com"

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# URL of the backend API (no trailing slash)
NEXT_PUBLIC_BACKEND_URL="http://localhost:8080"
# Must match CONDUCTOR_API_KEY above — exposed to browser (internal tool only)
NEXT_PUBLIC_CONDUCTOR_API_KEY="change-me-before-production"
